# /etc/mom/deny.list — packages denied to non-root users
# One or more package names / glob patterns per line, separated by spaces.
# Blank lines and lines beginning with # are ignored.
# Glob wildcards * and ? are supported (e.g. python3-* matches python3-dev).
#
# This file is generated at install time by merging deny/deny.list (generic)
# with deny/deny.apt.list or deny/deny.dnf.list (OS-specific).

# Exploitation & Attack Frameworks
metasploit-framework setoolkit beef-xss exploitdb armitage
veil veil-evasion veil-catapult empire powersploit
covenant sliver havoc cobalt-strike pwncat
impacket crackmapexec evil-winrm

